---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<Layout>
  <main class="mx-auto min-h-screen w-full max-w-4xl px-6 py-8 sm:px-10">
    <header class="mb-14 flex items-center justify-between text-sm">
      <div class="flex items-center gap-4">
        <a href="/">Aryan Gupta</a>
        <span>Blog</span>
      </div>
      <button id="theme-toggle" type="button" class="rounded border border-neutral-300 px-2 py-1 text-xs">
        Theme
      </button>
    </header>

    <h1 class="mb-8 text-3xl font-normal tracking-tight">Blog</h1>

    <ul class="space-y-5 text-sm">
      {
        posts.map((post) => (
          <li class="border-b border-neutral-200 pb-4">
            <article>
              <h2 class="mb-1 text-base font-normal">{post.data.title}</h2>
              <p class="mb-2 text-neutral-600">{post.data.description}</p>
              <time class="text-xs text-neutral-500" datetime={post.data.publishDate.toISOString()}>
                {post.data.publishDate.toLocaleDateString("en-US", {
                  month: "short",
                  day: "numeric",
                  year: "numeric",
                })}
              </time>
            </article>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
