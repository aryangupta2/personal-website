---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import HomeHeader from "../components/HomeHeader.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<Layout mainClass="mx-auto min-h-screen w-full max-w-3xl px-6 py-8 sm:px-10">
    <HomeHeader />

    <h1 class="mb-8 text-3xl font-normal tracking-tight">Blog</h1>

    <ul class="space-y-5 text-sm">
      {
        posts.map((post) => (
          <li class="border-b border-neutral-200 pb-4">
            <article>
              <h2 class="mb-1 text-base font-normal">{post.data.title}</h2>
              <p class="mb-2 text-neutral-600">{post.data.description}</p>
              <time class="text-xs text-neutral-500" datetime={post.data.publishDate.toISOString()}>
                {post.data.publishDate.toLocaleDateString("en-US", {
                  month: "short",
                  day: "numeric",
                  year: "numeric",
                })}
              </time>
            </article>
          </li>
        ))
      }
    </ul>
</Layout>
