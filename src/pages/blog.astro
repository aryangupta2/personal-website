---
import Layout from "../layouts/Layout.astro";
import HomeHeader from "../components/HomeHeader.astro";
---

<Layout mainClass="mx-auto min-h-screen w-full max-w-3xl px-6 py-8 sm:px-10">
  <HomeHeader />

  <h1 class="mb-8 text-3xl font-normal tracking-tight">Blog</h1>

  <section class="border-border border-t pt-10" aria-label="Blog status">
    <p class="text-muted max-w-xl text-sm leading-relaxed">
      This space is still taking shape. Longer notes on engineering, small
      tools, and lessons from shipping things will show up here when they are
      ready :)
    </p>
  </section>
</Layout>
