---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-6 py-8 sm:px-10">
		<header class="mb-16 flex items-center justify-between text-sm">
			<a href="/">Aryan Gupta</a>
			<nav aria-label="Primary" class="flex items-center gap-4">
				<a href="/blog">Blog</a>
				<a href="https://example.com/resume" target="_blank" rel="noreferrer noopener">Resume</a>
				<button id="theme-toggle" type="button" class="rounded border border-neutral-300 px-2 py-1 text-xs">
					Theme
				</button>
			</nav>
		</header>

		<section class="max-w-2xl">
			<h1 class="mb-3 text-3xl font-normal tracking-tight sm:text-4xl">Aryan Gupta</h1>
			<p class="mb-4 max-w-xl text-base leading-relaxed text-neutral-700">
				Software Developer
			</p>
			<p class="mb-8 max-w-xl text-sm leading-relaxed text-neutral-600">
				I focus on fast interfaces, automating where possible, and clear user experiences from idea to
				shipping.
			</p>

			<div class="mb-14 flex flex-wrap items-center gap-3 text-sm text-neutral-700">
				<a class="transition-colors hover:text-neutral-500" href="https://x.com" target="_blank" rel="noreferrer noopener">Twitter</a>
				<span aria-hidden="true" class="text-neutral-400">/</span>
				<a class="transition-colors hover:text-neutral-500" href="https://github.com" target="_blank" rel="noreferrer noopener">GitHub</a>
				<span aria-hidden="true" class="text-neutral-400">/</span>
				<a class="transition-colors hover:text-neutral-500" href="https://linkedin.com" target="_blank" rel="noreferrer noopener">LinkedIn</a>
			</div>
		</section>

		<section class="max-w-3xl">
			<h2 class="mb-5 text-base font-normal">Projects</h2>
			<ul class="space-y-4 text-sm">
				<li class="border-b border-neutral-200 pb-3">
					<a class="group flex items-center justify-between" href="#">
						<span>Developer Workflow Toolkit</span>
						<span class="text-neutral-500 transition-transform group-hover:translate-x-0.5">→</span>
					</a>
				</li>
				<li class="border-b border-neutral-200 pb-3">
					<a class="group flex items-center justify-between" href="#">
						<span>AI Notes Assistant</span>
						<span class="text-neutral-500 transition-transform group-hover:translate-x-0.5">→</span>
					</a>
				</li>
				<li class="border-b border-neutral-200 pb-3">
					<a class="group flex items-center justify-between" href="#">
						<span>Realtime Metrics Dashboard</span>
						<span class="text-neutral-500 transition-transform group-hover:translate-x-0.5">→</span>
					</a>
				</li>
			</ul>
		</section>
	</main>
</Layout>
