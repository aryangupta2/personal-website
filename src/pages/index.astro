---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-6 py-8 sm:px-10">
		<header class="mb-16 flex items-center justify-between text-sm">
			<span>Aryan Gupta</span>
			<nav aria-label="Primary">
				<a href="/">Home</a>
			</nav>
		</header>

		<section class="max-w-2xl">
			<h1 class="mb-3 text-3xl font-normal tracking-tight sm:text-4xl">Aryan Gupta</h1>
			<p class="mb-4 max-w-xl text-base leading-relaxed text-neutral-700">
				Software Developer
			</p>
			<p class="mb-8 max-w-xl text-sm leading-relaxed text-neutral-600">
				I focus on fast interfaces, automating where possible, and clear user experiences from idea to
				shipping.
			</p>

			<div class="mb-14 flex flex-wrap gap-5 text-sm">
				<a href="https://x.com" target="_blank" rel="noreferrer noopener">Twitter</a>
				<a href="https://github.com" target="_blank" rel="noreferrer noopener">GitHub</a>
				<a href="https://linkedin.com" target="_blank" rel="noreferrer noopener">LinkedIn</a>
			</div>
		</section>

		<section class="max-w-3xl">
			<h2 class="mb-5 text-base font-normal">Projects</h2>
			<ul class="space-y-4 text-sm">
				<li class="border-b border-neutral-200 pb-3">Project One</li>
				<li class="border-b border-neutral-200 pb-3">Project Two</li>
				<li class="border-b border-neutral-200 pb-3">Project Three</li>
			</ul>
		</section>
	</main>
</Layout>
