---
import { Image } from "astro:assets";
import profilePicture from "../assets/profile_picture.JPG";
---

<section class="max-w-xl">
  <button
    type="button"
    data-profile-open
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-label="Open profile picture fullscreen"
    class="mb-4 block rounded-full focus-visible:ring-2 focus-visible:ring-zinc-500 focus-visible:outline-none sm:mb-3 dark:focus-visible:ring-zinc-400"
  >
    <Image
      src={profilePicture}
      alt="Aryan Gupta profile picture"
      width={profilePicture.width}
      height={profilePicture.height}
      sizes="160px"
      densities={[1.5, 2]}
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="border-border h-36 w-36 rounded-full border object-cover object-center p-0.5 hover:scale-[1.02] sm:h-36 sm:w-36 md:h-40 md:w-40"
    />
  </button>
  <div
    data-profile-modal
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/92 p-4 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-label="Zoomed profile picture"
  >
    <figure
      class="relative z-[1] mx-auto flex w-fit max-w-[92vw] flex-col items-center"
    >
      <div class="relative inline-block max-w-full">
        <Image
          src={profilePicture}
          alt="Aryan Gupta profile picture enlarged"
          width={profilePicture.width}
          height={profilePicture.height}
          sizes="(max-width: 640px) 92vw, 85vw"
          loading="lazy"
          decoding="async"
          class="block h-auto max-h-[74vh] w-auto max-w-[92vw] rounded-2xl border border-white/20 object-contain shadow-2xl sm:max-h-[82vh] sm:max-w-[85vw]"
        />
        <button
          type="button"
          data-profile-close
          aria-label="Close profile picture zoom"
          class="absolute top-2 right-2 rounded-full border border-white/35 bg-black/55 p-2 text-white backdrop-blur-sm transition hover:bg-black/70 focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none sm:top-3 sm:right-3 sm:p-2.5"
        >
          <span class="sr-only">Close</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-4 sm:size-5"
            aria-hidden="true"
          >
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </button>
      </div>
      <figcaption
        class="mt-2 max-w-full px-1 text-center text-xs leading-snug text-white/90 sm:mt-3 sm:text-sm"
      >
        that time I went to lisbon
      </figcaption>
    </figure>
  </div>
  <h1 class="mb-2 text-3xl font-normal tracking-tight sm:text-4xl">
    Aryan Gupta
  </h1>
  <p class="mb-3 max-w-lg text-base leading-relaxed sm:mb-2">
    Software Developer
  </p>
  <p class="mb-6 max-w-lg text-sm leading-relaxed sm:mb-5">
    I focus on fast interfaces, automating where possible, and clear user
    experiences from idea to shipping. Outside of school and work, I enjoy
    travelling, staying active, and casually gaming.
    <br />
    <br />
    Always looking to chat! Feel free to reach out at my socials below :)
  </p>
</section>

<script>
  const openButton = document.querySelector("[data-profile-open]");
  const modal = document.querySelector("[data-profile-modal]");
  const closeButton = modal?.querySelector("[data-profile-close]");
  let previousFocus = null;

  const detachEscapeClose = () => {
    document.removeEventListener("keydown", onEscapeKey);
  };

  const closeModal = () => {
    if (!modal || !openButton) return;
    detachEscapeClose();
    modal.classList.add("hidden");
    document.body.classList.remove("overflow-hidden");
    openButton.setAttribute("aria-expanded", "false");
    previousFocus?.focus();
  };

  /** Only active while modal is visible */
  function onEscapeKey(event) {
    if (event.key !== "Escape") return;
    event.preventDefault();
    closeModal();
  }

  const openModal = () => {
    if (!modal || !openButton || !closeButton) return;
    previousFocus = document.activeElement;
    modal.classList.remove("hidden");
    document.body.classList.add("overflow-hidden");
    openButton.setAttribute("aria-expanded", "true");
    document.addEventListener("keydown", onEscapeKey);
    closeButton.focus();
  };

  openButton?.addEventListener("click", openModal);
  closeButton?.addEventListener("click", closeModal);

  modal?.addEventListener("click", (event) => {
    if (event.target !== modal) return;
    closeModal();
  });
</script>
