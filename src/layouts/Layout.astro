---
import "../styles/global.css";

interface Props {
	mainClass?: string;
}

const { mainClass = "mx-auto flex min-h-screen w-full max-w-3xl flex-col px-6 py-8 sm:px-10" } =
	Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Aryan Gupta</title>
		<script is:inline>
			const storedTheme = localStorage.getItem("theme");
			const preferredDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
			if (storedTheme === "dark" || (!storedTheme && preferredDark)) {
				document.documentElement.classList.add("dark");
			}
		</script>
	</head>
	<body>
		<main class={mainClass}>
			<slot />
		</main>
		<script is:inline>
			const buttons = document.querySelectorAll("#theme-toggle");
			const syncThemeIcons = () => {
				const isDark = document.documentElement.classList.contains("dark");
				document.querySelectorAll("[data-theme-icon-light]").forEach((icon) => {
					icon.classList.toggle("hidden", isDark);
				});
				document.querySelectorAll("[data-theme-icon-dark]").forEach((icon) => {
					icon.classList.toggle("hidden", !isDark);
				});
			};

			syncThemeIcons();

			buttons.forEach((button) => {
				button.addEventListener("click", () => {
					const html = document.documentElement;
					html.classList.toggle("dark");
					localStorage.setItem("theme", html.classList.contains("dark") ? "dark" : "light");
					syncThemeIcons();
				});
			});
		</script>
	</body>
</html>
